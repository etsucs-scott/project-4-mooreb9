@page "/"
@page "/habits"
@rendermode InteractiveServer

@using HabitTracker.Models
@using HabitTracker.Services
@using Microsoft.AspNetCore.Components.Web

@inject IHabitService HabitService

<h1 class="mb-3">Habit Tracker</h1>

<!-- Today's Progress -->
<div class="card p-3 mb-4 shadow-sm">
    <h4>Today's Progress</h4>

    <p>
        @todayCompleted / @habits.Count habits completed
        (@Math.Round(todayProgress)%)
    </p>

    <div class="progress" style="height: 20px;">
        <div class="progress-bar bg-success"
             style="width: @todayProgress%">
        </div>
    </div>
</div>

<!-- Filter -->
<div class="mb-3">
    <select @bind="selectedCategory" class="form-control">
        <option value="All">All Categories</option>
        @foreach (var category in categories)
        {
            <option value="@category">@category</option>
        }
    </select>
</div>

<!-- Add Habit -->
<div class="card p-3 mb-4 shadow-sm">
    <h5>Add New Habit</h5>

    <input @bind="newName"
           @onkeydown="HandleKey"
           class="form-control mb-2"
           placeholder="Habit name" />

    <input @bind="newDescription"
           class="form-control mb-2"
           placeholder="Description" />

    <select @bind="newCategory" class="form-control mb-2">
        @foreach (var category in categories.Where(c => c != "All"))
        {
            <option value="@category">@category</option>
        }
    </select>

    <button class="btn btn-primary"
            @onclick="AddHabit"
            disabled="@string.IsNullOrWhiteSpace(newName)">
        Add Habit
    </button>
</div>

@if (!FilteredHabits.Any())
{
    <p>No habits found. Start by adding your first habit above!</p>
}
else
{
    @foreach (var habit in FilteredHabits)
    {
        <div class="card p-3 mb-3 shadow-sm">

            @if (editingHabitId == habit.Id)
            {
                <!-- EDIT MODE -->
                <input @bind="editName" class="form-control mb-2" />
                <input @bind="editDescription" class="form-control mb-2" />

                <select @bind="editCategory" class="form-control mb-2">
                    @foreach (var category in categories.Where(c => c != "All"))
                    {
                        <option value="@category">@category</option>
                    }
                </select>

                <div class="d-flex gap-2">
                    <button class="btn btn-success"
                            @onclick="() => SaveEdit(habit.Id)">
                        Save
                    </button>

                    <button class="btn btn-secondary"
                            @onclick="CancelEdit">
                        Cancel
                    </button>
                </div>
            }
            else
            {
                <!-- VIEW MODE -->
                <h4>@habit.Name</h4>
                <p>@habit.Description</p>

                <p>
                    <strong>Category:</strong>
                    <span style="
                                    background-color: @GetCategoryColor(habit.Category);
                                    color: white;
                                    padding: 4px 8px;
                                    border-radius: 6px;">
                        @habit.Category
                    </span>
                </p>

                <p><strong>Streak:</strong> @habit.Streak</p>

                <!-- Weekly Tracker -->
                <p class="mb-1"><strong>This Week</strong></p>

                <div class="d-flex gap-2 mt-2">
                    @foreach (var day in weekDays)
                    {
                        bool completed = habit.IsCompletedOn(day);

                        <div style="
                                            width: 45px;
                                            height: 45px;
                                            border-radius: 8px;
                                            display: flex;
                                            align-items: center;
                                            justify-content: center;
                                            font-size: 12px;
                                            background-color: @(completed ? "#28a745" : "#dee2e6");
                                            color: @(completed ? "white" : "black");">
                            @day.ToString("ddd")
                        </div>
                    }
                </div>

                <!-- Weekly Progress -->
                <div class="mt-3">
                    <p class="mb-1">
                        <strong>Weekly Progress:</strong>
                        @GetWeeklyCompleted(habit)/7 days
                        (@Math.Round(GetWeeklyProgress(habit))%)
                    </p>

                    <div class="progress" style="height: 20px;">
                        <div class="progress-bar @(GetWeeklyProgress(habit) == 100 ? "bg-success" : "bg-primary")"
                             style="width: @GetWeeklyProgress(habit)%">
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-success"
                            disabled="@habit.IsCompletedToday()"
                            @onclick="() => Complete(habit.Id)">
                        @(habit.IsCompletedToday() ? "Done Today ✅" : "Complete")
                    </button>

                    <button class="btn btn-warning"
                            @onclick="() => StartEdit(habit)">
                        Edit
                    </button>

                    <button class="btn btn-danger"
                            @onclick="() => Delete(habit.Id)">
                        Delete
                    </button>
                </div>
            }
        </div>
    }
}

@code {
    private List<Habit> habits = new();

    private string newName = "";
    private string newDescription = "";
    private string newCategory = "General";

    private string selectedCategory = "All";

    private Guid? editingHabitId = null;
    private string editName = "";
    private string editDescription = "";
    private string editCategory = "General";

    private List<string> categories = new()
    {
        "All", "General", "Health", "School", "Fitness", "Productivity"
    };

    private List<DateTime> weekDays = new();

    private int todayCompleted => habits.Count(h => h.IsCompletedToday());

    private double todayProgress =>
        habits.Count == 0 ? 0 :
        (todayCompleted / (double)habits.Count) * 100;

    protected override void OnInitialized()
    {
        LoadHabits();
        weekDays = GenerateWeekDays();
    }

    private void LoadHabits()
    {
        try
        {
            habits = HabitService.GetHabits().ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading habits: {ex.Message}");
        }
    }

    private List<Habit> FilteredHabits =>
        habits.Where(h => selectedCategory == "All" || h.Category == selectedCategory).ToList();

    private void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AddHabit();
    }

    private void AddHabit()
    {
        try
        {
            HabitService.AddHabit(newName, newDescription, newCategory);
            LoadHabits();

            newName = "";
            newDescription = "";
            newCategory = "General";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adding habit: {ex.Message}");
        }
    }

    private void Complete(Guid id)
    {
        try
        {
            HabitService.CompleteHabit(id);
            LoadHabits();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error completing habit: {ex.Message}");
        }
    }

    private void Delete(Guid id)
    {
        try
        {
            HabitService.DeleteHabit(id);
            LoadHabits();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting habit: {ex.Message}");
        }
    }

    private void StartEdit(Habit habit)
    {
        editingHabitId = habit.Id;
        editName = habit.Name;
        editDescription = habit.Description;
        editCategory = habit.Category;
    }

    private void SaveEdit(Guid id)
    {
        try
        {
            HabitService.UpdateHabit(id, editName, editDescription, editCategory);
            editingHabitId = null;
            LoadHabits();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating habit: {ex.Message}");
        }
    }

    private void CancelEdit()
    {
        editingHabitId = null;
    }

    private List<DateTime> GenerateWeekDays()
    {
        var today = DateTime.UtcNow.Date;
        int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
        var monday = today.AddDays(-diff);

        return Enumerable.Range(0, 7)
            .Select(i => monday.AddDays(i))
            .ToList();
    }

    private int GetWeeklyCompleted(Habit habit)
    {
        return weekDays.Count(day => habit.IsCompletedOn(day));
    }

    private double GetWeeklyProgress(Habit habit)
    {
        return GetWeeklyCompleted(habit) / 7.0 * 100;
    }

    private string GetCategoryColor(string category)
    {
        return category switch
        {
            "Health" => "#28a745",
            "Fitness" => "#007bff",
            "School" => "#ffc107",
            "Productivity" => "#6f42c1",
            _ => "#6c757d"
        };
    }
}